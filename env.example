# local-memory-kit 설정 템플릿 — 이 파일을 .env 로 복사해 값 채우기.
#   cp env.example .env
# .env 는 실제 키를 담으므로 커밋 금지(.gitignore됨). 이 템플릿(env.example)만 커밋.
#
# 동작: `npm run setup` 이 .env 를 읽어 ① launchd plist 생성(서버용)
#       ② ~/.zshrc 에 ".env source 1줄" 추가(플러그인이 모든 터미널/프로젝트에서 자동 로드).

# 추출 모델 — tool(함수) 호출 지원 + reasoning 누출 없음 필수.
# 권장 gemma4:e4b / 대안 llama3.1:8b, mistral-nemo:12b  (Gemma3·순수 reasoning 모델은 부적합)
SM_MODEL=gemma4:e4b

# supermemory 서버 포트
SM_PORT=6767

# 플러그인 → 로컬 서버 연결 (setup 이 첫 부팅 후 키를 자동 기록)
SUPERMEMORY_API_URL=http://localhost:6767
SUPERMEMORY_CC_API_KEY=sm_여기에_로컬_서버_키

# 캡처 제외 도구(쉼표 구분) — 큰 트랜스크립트 캡처를 줄여 추출 실패율↓
SUPERMEMORY_SKIP_TOOLS=Bash
